#-------------------------
# Operating Specific Junk Files
#-------------------------

# OS X
.DS_Store
.AppleDouble
.LSOverride

# OS X Thumbnails
._*

# Windows image file caches
Thumbs.db
ehthumbs.db
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows Installer files
*.cab
*.msi
*.msm
*.msp

# Windows shortcuts
*.lnk

# Linux
*~

# KDE directory preferences
.directory

# Linux trash folder which might appear on any partition or disk
.Trash-*

#-------------------------
# Environment Files
#-------------------------
# These should never be under version control,
# as it poses a security risk.
.env
.vagrant
Vagrantfile

#-------------------------
# Temporary Files
#-------------------------
/writable/cache/*
!/writable/cache/index.html

/writable/logs/*
!/writable/logs/index.html

/writable/session/*
!/writable/session/index.html

/writable/uploads/*
!/writable/uploads/index.html

/writable/debugbar/*
!/writable/debugbar/index.html

php_errors.log

#-------------------------
# User Guide Temp Files
#-------------------------
/user_guide_src/build/*
/user_guide_src/cilexer/build/*
/user_guide_src/cilexer/dist/*
/user_guide_src/cilexer/pycilexer.egg-info/*

#-------------------------
# Test Files
#-------------------------
/tests/coverage*

# Don't save phpunit under version control.
/phpunit

#-------------------------
# Composer
#-------------------------
vendor/

#-------------------------
# npm
#-------------------------
node_modules/
package-lock.json

#-------------------------
# IDE / Development Files
#-------------------------

# Modules Testing
_modules/*

# phpenv local config
.php-version

# Jetbrains editors (PHPStorm, etc)
.idea/
*.iml

# NetBeans
/nbproject/
/build/
/nbbuild/
/dist/
/nbdist/
/nbactions.xml
/nb-configuration.xml
/.nb-gradle/

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project
.phpintel
/api/

# Visual Studio Code
.vscode/

/results/
/phpunit.xml

#-------------------------
# Documentation & Design Assets
#-------------------------
# Internal documentation, design drafts, and source diagrams are kept
# outside of version control (kept locally only).
/Documents/
/Diagrams/

#-------------------------
# Scratch / Debug Scripts
#-------------------------
# One-off probe, seed, debug, and smoke-test scripts used during development.
/scratch/

# Heredoc-based one-shot write scripts (write_*.php / find_*.php / test_*.php)
# created in the project root during refactors. They are intentionally
# committed only if the team decides to keep them.
/write_*.php
/find_*.php
/test_*.php

#-------------------------
# XAMPP / Runtime Artifacts
#-------------------------
# /syncookie/ is a XAMPP session/cookie helper binary.
/syncookie

# `builds/` directory holds prebuilt project archives and should never
# be tracked. (The `builds` FILE in the project root is a legitimate
# CodeIgniter Spark CLI script and IS tracked.)
/builds/*

#-------------------------
# Database Dumps
#-------------------------
# Local development SQL dumps under /Database/ and /database/ must
# not be committed — they may contain student/staff PII.
# (Keep the schema migration files under app/Database/Migrations/ tracked
#  — those are not affected by these patterns.)
/Database/*.sql
/database/*.sql
